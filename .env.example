# Frontend (Vite) - uses anon key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_FUNCTIONS_URL=https://your-project-id.supabase.co/functions/v1

# Note: Backend now uses Supabase Edge Functions
# The following secrets are configured via: supabase secrets set NAME=value
# - SUPABASE_URL (automatically available to Edge Functions)
# - SUPABASE_SERVICE_ROLE_KEY (automatically available to Edge Functions)
# - CONVEX_OPENAI_BASE_URL
# - CONVEX_OPENAI_API_KEY
